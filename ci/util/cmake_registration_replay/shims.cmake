  set(CUB_ENABLE_LAUNCH_GRAPH_LAUNCHER OFF)
elseif (ROW STREQUAL "nolauncher")
  set(CUB_ENABLE_LAUNCH_NO_LAUNCHER OFF)
elseif (ROW STREQUAL "clanghost")
