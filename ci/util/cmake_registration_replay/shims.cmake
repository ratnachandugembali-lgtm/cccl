macro(cccl_get_rapids_test)
  set(rapids-cmake_SOURCE_DIR "${RAPIDS_SRC}")
  # rapids' spec generator requires an enabled CXX/CUDA language; the replay
  # project is LANGUAGES NONE, so fake the global property it checks:
  include("${RAPIDS_SRC}/rapids-cmake/test/init.cmake")
  include("${RAPIDS_SRC}/rapids-cmake/test/gpu_requirements.cmake")
  # Pre-include the spec generator so its include_guard(GLOBAL) blocks the
  # re-include rapids_test_init() performs at call time; then replace it
  # with a recorder (the real one fatals under LANGUAGES NONE). Identical on
  # both replay sides, so parity comparisons are unaffected.
  include("${RAPIDS_SRC}/rapids-cmake/test/generate_resource_spec.cmake")
  function(rapids_test_generate_resource_spec DESTINATION filepath)
    _record(rapids_test_generate_resource_spec ${ARGV})
  endfunction()
endmacro()

