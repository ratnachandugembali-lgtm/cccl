set(CUB_ENABLE_LAUNCH_DEVICE_LAUNCHER ON)
set(CUB_ENABLE_LAUNCH_GRAPH_LAUNCHER ON)
set(CUB_ENABLE_RDC_TESTS ON)
set(CUB_FORCE_RDC OFF)
set(CMAKE_CXX_COMPILER_ID "GNU")
set(CMAKE_CXX_COMPILER_VERSION "13.2.0")
set(CMAKE_CUDA_COMPILER_ID "NVIDIA")
