  set(CMAKE_CUDA_COMPILER_ID "Clang")
  set(CMAKE_CUDA_COMPILER_VERSION "22.1.0") # -Wno-pass-failed tail quirk
else()
  message(FATAL_ERROR "unknown ROW=${ROW}")
endif()

# ---- event recorder ---------------------------------------------------------
string(ASCII 31 _replay_us) # unit separator: survives inside recorded args
set_property(GLOBAL PROPERTY replay_events "")
function(_record kind)
  set(line "${kind}")
  foreach (arg IN LISTS ARGN)
    string(APPEND line "${_replay_us}${arg}")
  endforeach()
  set_property(GLOBAL APPEND PROPERTY replay_events "${line}")
endfunction()
function(replay_dump)
  get_property(events GLOBAL PROPERTY replay_events)
  list(JOIN events "\n" events)
  file(WRITE "${CMAKE_BINARY_DIR}/events.log" "${events}\n")
  message(STATUS "replay: wrote ${CMAKE_BINARY_DIR}/events.log")
endfunction()

# ---- shadowed built-ins (originals available as _<name>) --------------------
function(add_test)
  _record(add_test ${ARGV})
endfunction()
function(set_tests_properties)
  _record(set_tests_properties ${ARGV})
endfunction()
function(set_target_properties)
  _record(set_target_properties ${ARGV})
endfunction()
function(set_property kind)
  if (kind STREQUAL "TEST")
    _record(set_property ${ARGV})
  else()
    _set_property(${ARGV})
  endif()
endfunction()
function(add_library name)
  _record(add_library ${ARGV})
  if (NOT TARGET ${name})
    _add_library(${name} INTERFACE)
  endif()
endfunction()
function(add_executable name)
  _record(add_executable ${ARGV})
  if (NOT TARGET ${name})
    _add_library(${name} INTERFACE)
  endif()
endfunction()
function(target_link_libraries)
  _record(target_link_libraries ${ARGV})
endfunction()
function(target_include_directories)
  _record(target_include_directories ${ARGV})
endfunction()
function(target_compile_definitions)
  _record(target_compile_definitions ${ARGV})
endfunction()
function(target_compile_options)
  _record(target_compile_options ${ARGV})
endfunction()
